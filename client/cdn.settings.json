{
  "profiles": {
    "react": {
      "dependencies": [
        "react",
        "react-dom"
      ],
      "external": [
        "react",
        "react-dom",
        "react/jsx-runtime"
      ]
    },
    "reactRouter": {
      "dependencies": [
        "react",
        "react-dom"
      ],
      "external": [
        "react",
        "react-dom",
        "react/jsx-runtime",
        "@remix-run/router"
      ]
    },
    "reactRouterDom": {
      "dependencies": [
        "react",
        "react-dom"
      ],
      "external": [
        "react",
        "react-dom",
        "react/jsx-runtime",
        "react-router",
        "react-router/dom",
        "@remix-run/router"
      ]
    }
  },
  "imports": {
    "react": {
      "global": "React"
    },
    "react-dom": {
      "global": "ReactDOMRoot"
    },
    "react-dom/client": {
      "global": "ReactDOMClient"
    },
    "react-use-websocket": {
      "global": "ReactUseWebsocket",
      "profile": "react"
    },
    "recharts": {
      "global": "Recharts",
      "profile": "react"
    },
    "react-router": {
      "global": "ReactRouter",
      "profile": "reactRouter"
    },
    "react-router/dom": {
      "global": "ReactRouterDomInternal",
      "profile": "reactRouter"
    },
    "react-router-dom": {
      "global": "ReactRouterDom",
      "profile": "reactRouterDom"
    },
    "html2canvas": {
      "global": "html2canvas"
    },
    "react-dnd": {
      "global": "ReactDnd",
      "profile": "react"
    },
    "@remix-run/router": {
      "global": "RemixRouter"
    },
    "@auth0/auth0-react": {
      "global": "Auth0React",
      "profile": "react"
    },
    "@js-joda/core": {
      "global": "Joda"
    },
    "react-flip-toolkit": {
      "global": "ReactFlipToolkit",
      "profile": "react"
    },
    "marked": {
      "global": "Marked"
    },
    "@emotion/css": {
      "global": "EmotionCss"
    },
    "fitty": {
      "global": "Fitty"
    },
    "drag-drop-webkit-mobile": {
      "global": "DDWM"
    },
    "react/jsx-runtime": {
      "global": "ReactJsxRuntime"
    }
  }
}
