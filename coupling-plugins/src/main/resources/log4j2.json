{
  "Configuration": {
    "Appenders": {
      "Console": {
        "JsonLayout": {
          "keyValuePair": [{
            "key": "timestamp",
            "value": "$${date:yyyy-MM-dd'T'HH:mm:ss.SSSZ}"
          },{
            "key": "testRunIdentifier",
            "value": "$${sys:testRunIdentifier}"
          }],
          "includeTimeMillis": true,
          "eventEol": true,
          "compact": true,
          "objectMessageAsJsonObject": true
        },
        "name": "Console",
        "target": "SYSTEM_OUT"
      }
    },
    "Loggers": {
      "Root": {
        "AppenderRef": [
          {
            "ref": "Console"
          }
        ],
        "level": "trace"
      }
    }
  }
}
